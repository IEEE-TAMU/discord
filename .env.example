# Discord
DISCORD_TOKEN=your_discord_bot_token_here
MONITOR_CHANNEL_ID=your_discord_channel_id_to_monitor

# API Configuration
API_PORT=3000
GUILD_ID=your_discord_guild_id_here

# Optional: Set to production for production environment
NODE_ENV=development

# Calendar Sync
# Public ICS URL of the iCal feed
CALENDAR_ICS_URL=
# How frequently to sync, in minutes
CALENDAR_SYNC_INTERVAL_MINUTES=10

# Kanban Module
# devenv defaults:
KANBAN_DB_HOST=127.0.0.1
KANBAN_DB_PORT=3306
KANBAN_DB_USER=discord
KANBAN_DB_PASSWORD=discord
KANBAN_DB_NAME=discord
