{
  "name": "ieee-tamu-discord-bot",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "rm -rf dist && tsup src/index.ts --minify && mkdir -p dist/migrations/kanban && cp -r src/modules/kanban/migrations dist/migrations/kanban",
    "lint": "eslint src --fix",
    "clear-commands": "tsx scripts/clear-commands.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.25.0"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/sql": "^0.51.0",
    "@effect/sql-drizzle": "^0.50.0",
    "@effect/sql-mysql2": "^0.52.0",
    "cors": "^2.8.5",
    "discord.js": "^14.18.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.0",
    "express": "^5.1.0",
    "mysql2": "^3.22.3",
    "node-ical": "^0.27.0"
  }
}
