{
  "name": "ieee-tamu-discord-bot",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "rm -rf dist && tsup src/index.ts --minify && mkdir -p dist/modules/kanban/db && cp -r src/modules/kanban/db/migrations dist/modules/kanban/db/migrations",
    "lint": "eslint src --fix",
    "clear-commands": "tsx scripts/clear-commands.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.25.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "discord.js": "^14.18.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "mysql2": "^3.23.1",
    "node-cron": "^4.6.0",
    "node-ical": "^0.27.0"
  }
}
